{
    "$schema": "vendor/infection/infection/resources/schema.json",
    "source": {
        "directories": [
            "Classes"
        ],
        "excludes": [
            "Authentication"
        ]
    },
    "phpUnit": {
        "configDir": "Build/phpunit"
    },
    "testFramework": "phpunit",
    "timeout": 30,
    "logs": {
        "text": "var/log/infection.log",
        "summary": "var/log/infection-summary.log",
        "html": "var/log/infection.html"
    },
    "mutators": {
        "@default": true,
        "IdenticalEqual": {
            "ignore": [
                "WebConsulting\\WorkosAuth\\Security\\StateService::consume"
            ]
        }
    },
    "minMsi": 70,
    "minCoveredMsi": 80
}
