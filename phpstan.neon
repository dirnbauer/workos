parameters:
    # Analyze against PHP 8.3 syntax rules even when CI executes PHPStan
    # on newer runtimes. PHP 8.5 reports property #[Override] opportunities,
    # but that attribute target is not valid on PHP 8.3 and lower.
    phpVersion: 80300
    level: max
    paths:
        - Classes
        - Configuration
        - Tests
        - ext_localconf.php
    stubFiles:
        - Build/phpstan/stubs/WorkOsResources.stub
        - Build/phpstan/stubs/WorkOsClients.stub
    tmpDir: var/cache/phpstan
    treatPhpDocTypesAsCertain: false
    reportUnmatchedIgnoredErrors: true
    checkMissingOverrideMethodAttribute: true
    typo3:
        containerXmlPath: null
        requestGetAttributeMapping:
            'frontend.user': 'TYPO3\CMS\Frontend\Authentication\FrontendUserAuthentication'
            normalizedParams: 'TYPO3\CMS\Core\Http\NormalizedParams'
            site: 'TYPO3\CMS\Core\Site\Entity\Site'
    phpat:
        show_rule_names: true
        ignore_doc_comments: true

services:
    -
        class: WebConsulting\WorkosAuth\Tests\Architecture\LayeringTest
        tags:
            - phpat.test
