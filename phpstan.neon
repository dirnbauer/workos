parameters:
    level: 9
    paths:
        - Classes
        - Configuration
        - Tests
        - ext_emconf.php
        - ext_localconf.php
        - ext_tables.sql
    excludePaths:
        - ext_tables.sql
    tmpDir: var/cache/phpstan
    treatPhpDocTypesAsCertain: false
    reportUnmatchedIgnoredErrors: true
    ignoreErrors:
        -
            identifier: missingType.iterableValue
