; Top-most EditorConfig file
root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true
max_line_length = 120

[*.{md,rst}]
trim_trailing_whitespace = false
max_line_length = 80

[*.{yml,yaml,neon}]
indent_size = 2

[*.{html,js,json,ts,css,scss}]
indent_size = 2

[composer.json]
indent_size = 4

[Makefile]
indent_style = tab
