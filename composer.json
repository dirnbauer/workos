{
    "name": "webconsulting/workos-auth",
    "description": "TYPO3 v14 extension for WorkOS-powered frontend and backend login (AuthKit, SSO, MFA, Admin Portal).",
    "type": "typo3-cms-extension",
    "license": "GPL-2.0-or-later",
    "keywords": [
        "typo3",
        "typo3-cms-extension",
        "authentication",
        "sso",
        "workos",
        "oidc",
        "mfa"
    ],
    "homepage": "https://github.com/webconsulting/typo3-workos-auth",
    "authors": [
        {
            "name": "webconsulting",
            "email": "office@webconsulting.at",
            "homepage": "https://webconsulting.at",
            "role": "Developer"
        }
    ],
    "support": {
        "issues": "https://github.com/webconsulting/typo3-workos-auth/issues",
        "source": "https://github.com/webconsulting/typo3-workos-auth"
    },
    "require": {
        "php": "^8.2",
        "typo3/cms-backend": "^14.0",
        "typo3/cms-core": "^14.0",
        "typo3/cms-extbase": "^14.0",
        "typo3/cms-fluid": "^14.0",
        "typo3/cms-frontend": "^14.0",
        "workos/workos-php": "^4.32"
    },
    "require-dev": {
        "phpat/phpat": "^0.11",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpunit/phpunit": "^11.5",
        "saschaegerer/phpstan-typo3": "^3.0",
        "typo3/testing-framework": "^9.2"
    },
    "autoload": {
        "psr-4": {
            "WebConsulting\\WorkosAuth\\": "Classes/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "WebConsulting\\WorkosAuth\\Tests\\": "Tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "phpstan/extension-installer": true,
            "typo3/class-alias-loader": true,
            "typo3/cms-composer-installers": true
        }
    },
    "scripts": {
        "phpstan": "phpstan analyse --memory-limit=1G",
        "phpstan:baseline": "phpstan analyse --generate-baseline --memory-limit=1G",
        "test:unit": "phpunit -c Build/phpunit/UnitTests.xml",
        "test:functional": "phpunit -c Build/phpunit/FunctionalTests.xml"
    },
    "extra": {
        "typo3/cms": {
            "extension-key": "workos_auth"
        }
    }
}
